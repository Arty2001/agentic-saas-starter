# Copy to .env and adjust. Everything has a dev-friendly default — the only
# hard requirement to chat locally is a database and an LLM key (or a local
# OpenAI-compatible endpoint).

# --- Database (LangGraph checkpoints + observability tables) ---
AGENT_DB=postgresql+psycopg://postgres:postgres@localhost:5432/agent_platform

# --- LLM ---
DEFAULT_LLM_PROVIDER=openai        # openai | anthropic | deepseek | vllm
DEFAULT_LLM_MODEL=gpt-4o
# DEFAULT_LLM_BASE_URL=http://localhost:8000/v1   # required for vllm
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=INFO
ENV=dev
IS_DEV=true                        # dev auth mode: any login works when
                                   # AUTH_SERVICE_URL is unset

# --- Your SaaS (leave empty to run fully mocked) ---
# SAAS_API_URL=https://api.your-saas.example/v1
# AUTH_SERVICE_URL=https://auth.your-saas.example/v1

# --- Service-to-service auth (optional; used by scheduled regression runs) ---
# APPLICATION_TOKEN=
# SERVICE_ACCOUNT_USER=
